# Orchestrator 环境配置
# 复制此文件为 .env 并根据需要修改

# ============================================
# LLM 配置
# ============================================
# 后端类型: anthropic, openai, zhipuai, ollama, http, mock
LLM_BACKEND=zhipuai

# 模型名称
# 智谱 AI: glm-4-flash, glm-4, glm-4-plus, glm-4-long
# OpenAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# Anthropic: claude-sonnet-4-20250514, claude-3-5-sonnet-20241022
LLM_MODEL=glm-4-flash

# API Key (智谱 AI)
# 从 https://open.bigmodel.cn 获取
LLM_API_KEY=your-zhipuai-api-key

# API 基础 URL (可选，使用默认值即可)
# 智谱 AI: https://open.bigmodel.cn/api/paas/v4/
# OpenAI: https://api.openai.com/v1
# LLM_BASE_URL=

# 其他参数
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=60

# ============================================
# 智谱 AI 专用配置
# ============================================
ZHIPUAI_API_KEY=your-zhipuai-api-key

# ============================================
# Anthropic 专用配置
# ============================================
# ANTHROPIC_API_KEY=your-anthropic-key

# ============================================
# OpenAI 专用配置
# ============================================
# OPENAI_API_KEY=your-openai-key
